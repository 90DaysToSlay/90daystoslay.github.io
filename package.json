  "dependencies": {
    "@11ty/eleventy": "^3.1.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "diff": "^8.0.4",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0"
  }
