  "scripts": {
    "build": "npx @11ty/eleventy",
    "start": "npx @11ty/eleventy --serve",
    "test:compare": "npx playwright test --config=tests/playwright.config.ts",
    "test:compare:visual": "npx playwright test visual --config=tests/playwright.config.ts",
