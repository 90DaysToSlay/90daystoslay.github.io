<section class="section section--light">
  <div class="container">
    <h2 class="text-center text-purple" style="margin-bottom: var(--space-xl);">Check Out What People Say Behind My Back</h2>
    <div class="grid grid--2">
      {% for testimonial in testimonials %}
      <div class="testimonial-card">
        <img src="{{ testimonial.image }}" alt="{{ testimonial.name }}" class="testimonial-card__img" width="80" height="80" loading="lazy">
        <p class="testimonial-card__text">"{{ testimonial.text }}"</p>
        <p class="testimonial-card__author">{{ testimonial.name }} — {{ testimonial.role }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
